# Copy this file to config/api.env and fill in your own values.
# TRACEALIGN_API_KEY is required.
# TRACEALIGN_BASE_URL is optional for official OpenAI, but required for
# other OpenAI-compatible endpoints such as DashScope or proxy gateways.

TRACEALIGN_API_KEY=replace_with_your_api_key
TRACEALIGN_BASE_URL=https://your-openai-compatible-endpoint/v1
API_PROVIDER=custom
